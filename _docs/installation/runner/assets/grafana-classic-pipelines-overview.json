      "title": "Build memory utilization",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_MIMIR}"
      },
      "description": "Total build (`dind` pod) memory utilization as a percent of requests/limits.\n\nIf utilization is close to 100%, it indicates that the build is using all of its allocated memory, which may lead to performance issues or OOM (Out of Memory) kills.\n\nIf utilization is close to 0%, it indicates that the build is not using much memory, which may suggest over-provisioning.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "axisSoftMax": 1,
            "axisSoftMin": 0,
            "barAlignment": 0,
            "barWidthFactor": 0.6,
            "drawStyle": "line",
            "fillOpacity": 0,
            "gradientMode": "none",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "auto",
            "showValues": false,
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "area"
            }
          },
          "mappings": [],
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "light-red",
                "value": 0
              },
              {
                "color": "light-orange",
                "value": 0.2
              },
              {
                "color": "light-green",
                "value": 0.3
              },
              {
                "color": "light-orange",
                "value": 0.7
              },
              {
                "color": "light-red",
                "value": 0.8
              }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 34
      },
      "id": 17,
      "maxPerRow": 3,
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true,
          "sortBy": "Mean",
          "sortDesc": true
        },
        "tooltip": {
          "hideZeros": true,
          "mode": "multi",
          "sort": "desc"
        }
      },
      "pluginVersion": "12.3.1",
      "repeat": "percentile",
      "repeatDirection": "h",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_MIMIR}"
          },
          "editorMode": "code",
          "expr": "quantile(0.$percentile,\n    sum(\n        container_memory_working_set_bytes{cluster=~\"$cluster\", namespace=~\"$k8s_namespace_name\", container=\"dind\"}\n    ) by (pod)\n    /\n    sum(\n        kube_pod_container_resource_requests{cluster=~\"$cluster\", namespace=~\"$k8s_namespace_name\", container=\"dind\", resource=\"memory\"}\n    ) by (pod)\n    * on (pod)\n    sum(\n        label_replace(\n            codefresh_classic_build_info{cf_account_name=~\"$cf_account_name\", cluster=~\"$cluster\", k8s_namespace_name=~\"$k8s_namespace_name\", cf_classic_runtime_name=~\"$cf_classic_runtime_name\", cf_classic_pipeline_name=~\"$cf_classic_pipeline_name\", cf_classic_build_volume=~\"$cf_classic_build_volume\"},\n            \"pod\",\n            \"dind-$1\",\n            \"cf_classic_build_id\",\n            \"(.*)\"\n        )\n    ) by (pod)\n)",
          "hide": false,
          "instant": false,
          "legendFormat": "Requests",
          "range": true,
          "refId": "A"
        },
