          "editorMode": "code",
          "expr": "quantile(0.$percentile,\n    max_over_time(\n        (\n            sum(\n                {__name__=~\"codefresh_classic_build_step_completion_timestamp(_seconds)*$\", cf_account_name=~\"$cf_account_name\", cluster=~\"$cluster\", k8s_namespace_name=~\"$k8s_namespace_name\", cf_classic_runtime_name=~\"$cf_classic_runtime_name\", cf_classic_pipeline_name=~\"$cf_classic_pipeline_name\"}\n                -\n                {__name__=~\"codefresh_classic_build_step_start_timestamp(_seconds)*$\", cf_account_name=~\"$cf_account_name\", cluster=~\"$cluster\", k8s_namespace_name=~\"$k8s_namespace_name\", cf_classic_runtime_name=~\"$cf_classic_runtime_name\", cf_classic_pipeline_name=~\"$cf_classic_pipeline_name\"}\n            ) by (cf_classic_build_id, cf_classic_build_step_name)\n            * on (cf_classic_build_id, cf_classic_build_step_name)\n            sum(\n                codefresh_classic_build_step_info{cf_account_name=~\"$cf_account_name\", cluster=~\"$cluster\", k8s_namespace_name=~\"$k8s_namespace_name\", cf_classic_runtime_name=~\"$cf_classic_runtime_name\", cf_classic_pipeline_name=~\"$cf_classic_pipeline_name\", cf_classic_build_step_type=\"$pre_step_type\"}\n            ) by (cf_classic_build_id, cf_classic_build_step_name)\n            * on (cf_classic_build_id) group_left\n            sum(\n                codefresh_classic_build_info{cf_account_name=~\"$cf_account_name\", cluster=~\"$cluster\", k8s_namespace_name=~\"$k8s_namespace_name\", cf_classic_runtime_name=~\"$cf_classic_runtime_name\", cf_classic_pipeline_name=~\"$cf_classic_pipeline_name\", cf_classic_build_phase=~\"$cf_classic_build_phase_final\", cf_classic_build_volume=~\"$cf_classic_build_volume\"}\n            ) by (cf_classic_build_id)\n        )\n    [$aggregation_window:])\n) by (cf_classic_build_step_name)",
          "hide": false,
          "instant": false,
          "legendFormat": "__auto",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Build preparation duration, p$percentile",
      "type": "timeseries"
