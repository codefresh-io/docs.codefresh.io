      "title": "Total build duration",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_MIMIR}"
      },
      "description": "Total build duration, broken down by phases:\n\n* `preparing`: Build preparation duration. This phase is required to bootstrap the build and is reflected in the Codefresh UI as “Initializing Process.”\n* `running`: Build execution duration.\n* `finalizing`: Build finalization duration. This phase is required to gracefully terminate build execution and is not reflected in the Codefresh UI.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "barWidthFactor": 0.6,
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "hue",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "auto",
            "showValues": false,
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "normal"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "mappings": [],
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 1
      },
      "id": 10,
      "maxPerRow": 3,
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true,
          "sortBy": "Mean",
          "sortDesc": true
        },
        "tooltip": {
          "hideZeros": true,
          "mode": "multi",
          "sort": "desc"
        }
      },
      "pluginVersion": "12.3.1",
      "repeat": "percentile",
      "repeatDirection": "h",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_MIMIR}"
          },
          "editorMode": "code",
          "expr": "quantile(0.$percentile,\n    max_over_time(\n        (\n            sum(\n                {__name__=~\"codefresh_classic_build_phase_completion_timestamp(_seconds)*$\", cf_account_name=~\"$cf_account_name\", cluster=~\"$cluster\", k8s_namespace_name=~\"$k8s_namespace_name\", cf_classic_runtime_name=~\"$cf_classic_runtime_name\", cf_classic_pipeline_name=~\"$cf_classic_pipeline_name\", cf_classic_build_phase=~\"preparing|running|finalizing\"}\n                -\n                {__name__=~\"codefresh_classic_build_phase_start_timestamp(_seconds)*$\", cf_account_name=~\"$cf_account_name\", cluster=~\"$cluster\", k8s_namespace_name=~\"$k8s_namespace_name\", cf_classic_runtime_name=~\"$cf_classic_runtime_name\", cf_classic_pipeline_name=~\"$cf_classic_pipeline_name\", cf_classic_build_phase=~\"preparing|running|finalizing\"}\n            ) by (cf_classic_build_id, cf_classic_build_phase)\n            * on (cf_classic_build_id) group_left\n            sum(\n                codefresh_classic_build_info{cf_account_name=~\"$cf_account_name\", cluster=~\"$cluster\", k8s_namespace_name=~\"$k8s_namespace_name\", cf_classic_runtime_name=~\"$cf_classic_runtime_name\", cf_classic_pipeline_name=~\"$cf_classic_pipeline_name\", cf_classic_build_phase=~\"$cf_classic_build_phase_final\", cf_classic_build_volume=~\"$cf_classic_build_volume\"}\n            ) by (cf_classic_build_id)\n        )\n    [$aggregation_window:])\n) by (cf_classic_build_phase)",
          "hide": false,
          "instant": false,
          "legendFormat": "__auto",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Total build duration, p$percentile",
      "type": "timeseries"
    },
