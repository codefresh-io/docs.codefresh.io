            "type": "prometheus",
            "uid": "${DS_MIMIR}"
          },
          "editorMode": "code",
          "expr": "quantile(0.$percentile,\n    sum(\n        container_memory_working_set_bytes{cluster=~\"$cluster\", namespace=~\"$k8s_namespace_name\", container=\"dind\"}\n    ) by (pod)\n    /\n    sum(\n        kube_pod_container_resource_limits{cluster=~\"$cluster\", namespace=~\"$k8s_namespace_name\", container=\"dind\", resource=\"memory\"}\n    ) by (pod)\n    * on (pod)\n    sum(\n        label_replace(\n            codefresh_classic_build_info{cf_account_name=~\"$cf_account_name\", cluster=~\"$cluster\", k8s_namespace_name=~\"$k8s_namespace_name\", cf_classic_runtime_name=~\"$cf_classic_runtime_name\", cf_classic_pipeline_name=~\"$cf_classic_pipeline_name\", cf_classic_build_volume=~\"$cf_classic_build_volume\"},\n            \"pod\",\n            \"dind-$1\",\n            \"cf_classic_build_id\",\n            \"(.*)\"\n        )\n    ) by (pod)\n)",
          "hide": false,
          "instant": false,
          "legendFormat": "Limits",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "Build memory utilization, p$percentile",
      "type": "timeseries"
